#!/usr/bin/env bash
set -euo pipefail

NAME="nx"
NX_META=""

if [[ "$UID" == 0 ]]; then
  RED='\033[1;31m'
  RESET='\033[0m'
  echo -e "${RED}Error: Do not run directly as root due to config dir resolution${RESET}" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_PATH="$SCRIPT_DIR/scripts/deployment"

source "$SCRIPTS_PATH/../utils/pre-check.sh"
check_config_directory "help" "deployment"

if [[ -n "${NX_INSTALL_PATH:-}" && -f "$NX_INSTALL_PATH/nx-meta.json" ]]; then
    NX_META="$NX_INSTALL_PATH/nx-meta.json"
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
    if [[ -n "${NX_INSTALL_PATH:-}" && -f "$NX_INSTALL_PATH/nx-help.txt" ]]; then
        cat "$NX_INSTALL_PATH/nx-help.txt" >&2
    else
        echo "Usage: $NAME <command> [args...]" >&2
        echo "       $NAME --help" >&2
        echo "" >&2
        echo "Run '$NAME --help' from the installed version for full help." >&2
    fi
    exit 0
fi

if [[ "${1:-}" == "--version" ]]; then
    if [[ -n "$NX_META" ]]; then
        echo "$NAME version $(jq -r '.version' "$NX_META")" >&2
    else
        echo "$NAME local development version" >&2
    fi
    exit 0
fi

if [[ $# -eq 0 ]]; then
  if [[ "${ACTUAL_PWD:-$PWD}" == "$(realpath "$NXCORE_DIR")" ]]; then
    SCRIPT_NAME="status"
  else
    SCRIPT_NAME="core"
  fi
else
  SCRIPT_NAME="$1"
  shift
fi

SCRIPT_FILE="$SCRIPTS_PATH/$SCRIPT_NAME"

if [[ -e "${SCRIPT_FILE}.sh" ]]; then
    bash "${SCRIPT_FILE}.sh" "$@"
elif [[ -e "${SCRIPT_FILE}.py" ]]; then
    python "${SCRIPT_FILE}.py" "$@"
else
    if [[ "${SCRIPT_NAME:-}" == -* ]]; then
        echo -e "${RED}Error: unknown option '${WHITE}${SCRIPT_NAME:-}${RED}'${RESET}" >&2
        echo >&2
        if [[ -n "$NX_META" ]]; then
            OPTS=$(jq -r '.options | join(", ")' "$NX_META")
            echo -e "${CYAN}Available options: ${WHITE}${OPTS}${RESET}" >&2
        else
            echo -e "${CYAN}Try ${WHITE}$NAME --help${RESET}" >&2
        fi
    else
        echo -e "${RED}Error: unknown command '${WHITE}${SCRIPT_NAME:-}${RED}'${RESET}" >&2
        echo >&2
        if [[ -n "$NX_META" ]]; then
            CMDS=$(jq -r '.commands | join(", ")' "$NX_META")
            echo -e "${CYAN}Available commands: ${WHITE}${CMDS}${RESET}" >&2
            echo -e "${CYAN}Use ${WHITE}$NAME --help${CYAN} for details${RESET}" >&2
        else
            echo -e "${CYAN}Try ${WHITE}$NAME --help${RESET}" >&2
        fi
    fi
    exit 1
fi

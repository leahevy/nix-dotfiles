#!/usr/bin/env bash
set -euo pipefail

NX_SPEC=""

if [[ "$UID" == 0 ]]; then
  RED='\033[1;31m'
  RESET='\033[0m'
  echo -e "${RED}Error: Do not run directly as root due to config dir resolution${RESET}" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPTS_PATH="$SCRIPT_DIR/scripts/deployment"

source "$SCRIPTS_PATH/../utils/pre-check.sh"
check_config_directory "help" "deployment"

if [[ -n "${NX_INSTALL_PATH:-}" && "$SCRIPT_DIR" != "$NX_INSTALL_PATH" ]]; then
    unset NX_INSTALL_PATH
fi

if [[ -n "${NX_INSTALL_PATH:-}" && -f "$NX_INSTALL_PATH/nx-spec.json" ]]; then
    NX_SPEC="$NX_INSTALL_PATH/nx-spec.json"
fi

if [[ -n "$NX_SPEC" ]]; then
    NAME="$(jq -r '.name' "$NX_SPEC" 2>/dev/null || echo 'nx')"
else
    NAME="nx"
fi

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" || "${1:-}" == "help" ]]; then
    source "$SCRIPTS_PATH/../utils/nx-validate.sh"
    show_command_help ""
    exit 0
fi

if [[ "${1:-}" == "--version" ]]; then
    if [[ -n "$NX_SPEC" ]]; then
        echo "$NAME version $(jq -r '.version' "$NX_SPEC")" >&2
    else
        echo "$NAME local development version" >&2
    fi
    exit 0
fi

if [[ $# -eq 0 ]]; then
  if [[ "${ACTUAL_PWD:-$PWD}" == "$(realpath "$NXCORE_DIR")" ]]; then
    SCRIPT_NAME="status"
  else
    SCRIPT_NAME="core"
  fi
else
  SCRIPT_NAME="$1"
  shift

  source "$SCRIPTS_PATH/../utils/nx-validate.sh"

  help_requested=false
  for arg in "$@"; do
    if [[ "$arg" == "--help" || "$arg" == "-h" ]]; then
      help_requested=true
      break
    fi
  done

  if [[ "$help_requested" == "true" ]]; then
    cmd_path="$SCRIPT_NAME"
    for arg in "$@"; do
      if [[ "$arg" == "--help" || "$arg" == "-h" || "$arg" == --* || "$arg" == -* ]]; then
        break
      fi
      cmd_path="$cmd_path $arg"
    done
    show_command_help "$cmd_path"
  fi

  if ! validate_command "$SCRIPT_NAME" "$@"; then
    exit 1
  fi

  if [[ -n "$NX_SPEC" ]]; then
    readarray -d '' INJECTED_ARGS < <(inject_defaults_for_command "$SCRIPT_NAME" "$@")
    if [[ ${#INJECTED_ARGS[@]} -gt 0 ]] && [[ -z "${INJECTED_ARGS[-1]}" ]]; then
      unset 'INJECTED_ARGS[-1]'
    fi
    set -- "${INJECTED_ARGS[@]}"
  fi
fi

SCRIPT_FILE="$SCRIPTS_PATH/$SCRIPT_NAME"

if [[ -e "${SCRIPT_FILE}.sh" ]]; then
    bash "${SCRIPT_FILE}.sh" "$@"
elif [[ -e "${SCRIPT_FILE}.py" ]]; then
    python "${SCRIPT_FILE}.py" "$@"
else
    if [[ "${SCRIPT_NAME:-}" == -* ]]; then
        echo -e "${RED}Error: unknown option '${WHITE}${SCRIPT_NAME:-}${RED}'${RESET}" >&2
        echo >&2
        if [[ -n "$NX_SPEC" ]]; then
            OPTS=$(jq -r '.options | keys | map("--" + .) | join(", ")' "$NX_SPEC")
            echo -e "${CYAN}Available options: ${WHITE}${OPTS}${RESET}" >&2
        else
            echo -e "${CYAN}Try ${WHITE}$NAME --help${RESET}" >&2
        fi
    else
        echo -e "${RED}Error: unknown command '${WHITE}${SCRIPT_NAME:-}${RED}'${RESET}" >&2
        echo >&2
        if [[ -n "$NX_SPEC" ]]; then
            CMDS=$(jq -r '.subcommands | keys | join(", ")' "$NX_SPEC")
            echo -e "${CYAN}Available commands: ${WHITE}${CMDS}${RESET}" >&2
            echo -e "${CYAN}Use ${WHITE}$NAME --help${CYAN} for details${RESET}" >&2
        else
            echo -e "${CYAN}Try ${WHITE}$NAME --help${RESET}" >&2
        fi
    fi
    exit 1
fi
